{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/app/*": [
        "./src/app/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/components/*": [
        "./src/components/*",
        "./components/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/config/*": [
        "./src/config/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-playwright/types/**/*.ts",
    ".next-playwright/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "__tests__",
    "e2e",
    "artifacts",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
